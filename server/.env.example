# TechPulse AI Backend — Environment Configuration (Example)
# Copy this file to .env and fill in your values

# Server port
PORT=3001

# Cron schedule for automated report generation
# Development: every hour  => "0 * * * *"
# Production:  every day at 6AM => "0 6 * * *"
REPORT_GENERATION_SCHEDULE="0 * * * *"

# SQLite database file path (relative to server/ directory)
DB_PATH=./data/techpulse.db

# Optional: Set to "true" to force report generation on startup even if DB has data
FORCE_INITIAL_REPORT=false
